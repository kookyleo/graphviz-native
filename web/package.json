{
  "name": "graphviz-anywhere-web",
  "version": "0.1.0",
  "description": "Wasm-powered Graphviz renderer for browsers, Web Workers, and edge runtimes",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/nicekook/graphviz-anywhere.git",
    "directory": "web"
  },
  "author": "kookyleo <kookyleo@gmail.com>",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "import": "./dist/worker.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {},
  "devDependencies": {
    "@vitest/ui": "^2.1.8",
    "happy-dom": "^20.8.4",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "graphviz",
    "wasm",
    "web",
    "worker",
    "svg",
    "dot",
    "visualization"
  ]
}

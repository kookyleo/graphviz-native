{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "Bundler",
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "baseUrl": "../",
    "lib": [
      "ES2022",
      "DOM",
      "WebWorker"
    ]
  },
  "include": [
    "src/**/*.ts"
  ]
}
